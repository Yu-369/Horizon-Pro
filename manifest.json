{
  "manifest_version": 3,
  "name": "Horizon for YouTube™",
  "version": "1.3.0",
  "description": "Experience YouTube like never before with a stunning cinematic redesign, sleek infinite carousels, and an ultra-modern aesthetic.",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtubepro@example.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "Logo-16.png",
    "48": "Logo-48.png",
    "128": "Logo-128.png"
  },
  "action": {
    "default_icon": {
      "16": "Logo-16.png",
      "48": "Logo-48.png",
      "128": "Logo-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Horizon Pro Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject-quality.js"
      ],
      "matches": [
        "*://www.youtube.com/*"
      ]
    }
  ]
}